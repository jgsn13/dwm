#! /bin/bash

interval=0

_wlan() {
    case "$(cat /sys/class/net/w*/operstate 2>/dev/null)" in
        up) printf "^c#7aa2f7^ ’¬© Up%s" " ^d^" ;;
        down) printf "^c#ed0000^ ’¬® Down%s" " ^d^" ;;
    esac
}

_batt() {
    status=$(cat /sys/class/power_supply/BAT0/status)
    capacity=$(cat /sys/class/power_supply/BAT0/capacity)
#     notify_sent=0
#     if [ $notify_sent == 0 ] && [ "$status" == "Discharging" ] && [ "$capacity" == "92" ]; then
#         notify-send --urgency=CRITICAL "Battery Low"
#         notify_sent=1
#     else if [ "$status" == "Charging" ] && [ "$capacity" == "92" ]; then
#         notify_sent=0
#     fi
# 
    case "$status" in
        Full) printf "^c#46e25b^^b#282a36^ ’ĢĖ $capacity%s" "% ^d^" ;;
        Charging) printf "^c#ffaa00^^b#282a36^ ’¢ā $capacity%s" "% ^d^" ;;
        Discharging) printf "^c#ff5f32^^b#282a36^ ’¢é $capacity%s" "% ^d^" ;;
    esac
}

_date() {
    printf "^c#ff63dd^ ’ü│ $(date '+%b %d ^d^^c#d444fc^^b#282a36^ ’ĆŚ %H:%M')%s" " ^d^"
}

_vol() {
    printf "^c#aa00ff^^b#282a36^ ’®Į $(amixer get Master | tail -n1 | sed -r 's/.*\[(.*)%\].*/\1/')%s" "% ^d^"
}

_mem() {
    printf "^c#95ff49^ Ņē” $(free -h | awk '/^Mem/ { print $3 }' | sed s/i//g)%s" " ^d^"
}

_cpu() {
    printf "^c#ff6060^^b#282a36^ ’ĪÜ $(top -bn1 | grep 'Cpu(s)' | sed 's/.*, *\([0-9.]*\)%* id.*/\1/' | awk '{print 100 - $1}')%s" "% ^d^"
}

_updates() {
    updates=$(checkupdates | wc -l)   # arch , needs pacman contrib
    # updates=$(doas xbps-install -un | wc -l) # void
    # updates=$(aptitude search '~U' | wc -l)  # apt (ubuntu,debian etc)
    if [ -z "$updates" ]; then
        printf "^c#3d6dff^ ’Ż¢ 0%s" " ^d^"
    else
        printf "^c#3d6dff^ ’Ż¢ $updates%s" " ^d^"
    fi
}

_up_not_loaded() {
    printf ""
}

while :; do
    [ $interval == 0 ] || [ $(($interval % 3600)) == 0 ] && _updates=$(_up_not_loaded)
    interval=$((interval + 1))

    sleep 1 && xsetroot -name "$(_updates)$(_cpu)$(_mem)$(_vol)$(_wlan)$(_batt)$(_date)"
done
